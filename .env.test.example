# .env.test.example — copy to .env.test (gitignored) for running the test suite.
# Tests run against a SEPARATE database so the suite's cleanup never wipes your
# real/dev data. The ONLY line that must differ from .env is DATABASE_URL — it
# must point at portfolio_cms_test.

# Note the database name: portfolio_cms_test (NOT portfolio_cms).
DATABASE_URL="postgresql://app_user:devpassword@localhost:5432/portfolio_cms_test?schema=public"

# The rest can mirror .env (values don't matter much for tests, but env.ts
# validation still needs them present and well-formed).
NODE_ENV="test"
APP_URL="https://basantarana.com"
ADMIN_URL="https://admin.basantarana.com"
AUTH_SECRET="test-secret-at-least-32-characters-long-xxxxx"
ADMIN_COOKIE_DOMAIN="admin.basantarana.com"

# .env.example — copy to .env (gitignored) and fill in. NEVER commit .env.
# Validate these on startup with Zod so the app refuses to boot if any are
# missing/invalid (see lib/env.ts).

# --- Database (Prisma 7: connection string lives here, used via prisma.config.ts) ---
# Local dev: a local Postgres or Docker. Prod: the VPS localhost Postgres.
DATABASE_URL="postgresql://app_user:STRONG_PASSWORD@localhost:5432/portfolio_cms?schema=public"
# Optional direct URL for prisma CLI/migrations if you use a pooler in prod.
# DIRECT_URL="postgresql://app_user:STRONG_PASSWORD@localhost:5432/portfolio_cms"

# --- App ---
NODE_ENV="development"            # "production" on the VPS
APP_URL="https://basantarana.com"
ADMIN_URL="https://admin.basantarana.com"

# --- Auth / sessions ---
# A long random secret for signing sessions/JWTs. Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_LONG_RANDOM_AT_LEAST_32_CHARS"
# Session cookie scope — admin cookie is scoped to the admin host exactly.
ADMIN_COOKIE_DOMAIN="admin.basantarana.com"

# --- External platform stats (Phase: later; manual entry until then) ---
# Leave blank now. Scope least-privilege when you add them. Never expose to client.
# GITHUB_TOKEN=""
# YOUTUBE_API_KEY=""

# --- Observability (when you wire it) ---
# SENTRY_DSN=""

# -----------------------------------------------------------------------------
# Startup validation lives in lib/env.ts: it z.parse()es these on import and
# throws on boot if anything is missing/invalid. Import `env` from lib/env.ts
# everywhere instead of reading process.env directly — one validated, typed
# source of truth.

// Portfolio CMS — starter schema (Prisma 7)
// Connection string is in prisma.config.ts, NOT here (Prisma 7 change).
// Principle: columns you FILTER/SORT by are relational; render-only flexible
// content is Json (PostgreSQL JSONB). Every Json field has a Zod schema in
// lib/schemas/ and is validated on write AND read.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String                  // hashed (argon2/bcrypt) — never plaintext
  role      Role     @default(ADMIN) // multi-user-ready
  sessions  Session[]               // DB-backed sessions (Lucia pattern)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// DB-backed sessions. `id` stores the SHA-256 hash of the session token, NOT
// the token itself — the raw token lives only in the user's cookie. A DB leak
// therefore yields no usable tokens. expiresAt enables real, server-side
// invalidation (logout = delete the row) and sliding renewal.
model Session {
  id        String   @id            // sha256(token), hex
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  @@index([userId])
}

enum Role {
  ADMIN
  EDITOR
}

model Profile {
  id          String   @id @default(cuid())
  name        String
  headline    String
  email       String?
  location    String?
  // JSONB: short/medium/long variants, validated by Zod (BioVariantsSchema)
  bioVariants Json
  updatedAt   DateTime @updatedAt
  // NOTE: profile holds TEXT only. Avatar/background/cover/CV live in
  // MediaAsset (upload-many-activate-one), referenced in themes as
  // {{ profile.avatar }} etc. — the engine merges active media into profile.
}

model Project {
  id        String        @id @default(cuid())
  slug      String        @unique           // queryable -> relational
  title     String
  summary   String                          // short, used by compact themes
  status    ProjectStatus @default(DRAFT)   // filterable -> relational
  featured  Boolean       @default(false)   // filterable -> relational
  order     Int           @default(0)       // sortable -> relational
  // JSONB: array of typed content blocks (heading/text/image/code/embed...)
  content   Json
  // JSONB: this project's OWN images { thumbnail: "url", gallery: ["url",...] }.
  // Project images belong to the project (not the profile media library).
  // Uploaded via the project edit form, referenced as {{ project.thumbnail }}.
  media     Json?
  tags      ProjectTag[]                     // queryable -> relational join
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, featured, order])
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Tags are relational (not JSONB) BECAUSE you filter by them.
model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  projects ProjectTag[]
}

model ProjectTag {
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String
  @@id([projectId, tagId])
}

model Skill {
  id       String @id @default(cuid())
  name     String
  category String                       // filterable -> relational
  level    Int    @default(0)           // 0-100, sortable
  order    Int    @default(0)
  @@index([category, order])
}

model PlatformStat {
  id        String   @id @default(cuid())
  platform  String                       // "youtube","github","linkedin"...
  label     String                       // "Subscribers","Followers"
  value     Int      @default(0)         // manual value; used when no apiUrl set,
                                          // or as fallback when a fetch fails
  order     Int      @default(0)
  // OPTIONAL live stats. If apiUrl is set, a scheduled refresh fetches it,
  // walks apiPath into the JSON, and stores the number in cachedValue. Themes
  // then show cachedValue instead of `value`. Blank apiUrl = manual, as before.
  // apiUrl is SERVER-ONLY (may contain an API key) — never rendered to themes.
  apiUrl      String?                    // e.g. https://api.github.com/users/me
  apiPath     String?                    // dot path: "followers" or "items.0.statistics.subscriberCount"
  cachedValue Int?                       // last successfully fetched number
  fetchedAt   DateTime?                  // when cachedValue was last refreshed
  updatedAt DateTime @updatedAt
  @@unique([platform, label])
}

model Theme {
  id       String  @id @default(cuid())
  key      String  @unique               // matches a folder in themes/<key>/
  name     String
  isActive Boolean @default(false)
  // "builtin" -> rendered from the repo's themes/<key>/ dir (ships with code).
  // "uploaded" -> rendered from the writable THEME_UPLOAD_DIR/<key>/ dir, so
  // admin-uploaded themes survive redeploys. The engine resolves files by this.
  source   String  @default("builtin")
  // JSONB: the author's per-theme checklist of files they EXPECT this theme to
  // have, as [{ name, label }]. Lets a theme declare only the files it actually
  // uses (a minimal theme can hide unused page slots) and track custom-named
  // extras (skills.html, blog.css, …) that the engine doesn't read but the
  // author wants to remember to upload. Validated by Zod (ExpectedFilesSchema)
  // on write. Empty array = fall back to showing the standard named files.
  expectedFiles Json @default("[]")
}

model EngagementEvent {
  id         String   @id @default(cuid())
  type       String                       // "view","like"
  targetType String                       // "profile","project"
  targetId   String?
  // sessionId is set for LIKES (anonymous like_session cookie) so one visitor
  // can't like the same target twice. NULL for views. The unique index below
  // works for both: Postgres treats NULLs as distinct, so view rows never
  // collide, while like rows with the same session collide (idempotent).
  sessionId  String?
  createdAt  DateTime @default(now())
  @@unique([type, targetType, targetId, sessionId])
  @@index([targetType, targetId, type])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)   // admin marks read/unread in the inbox
  createdAt DateTime @default(now())

  @@index([read, createdAt])
}

// Media library: upload many per type, activate one. Same pattern as Theme.
// slotOrder: when set, this asset is in use at that numbered position for its
// type (image1, image2, cover1, video3, etc.). Null means in the library only.
// Uniqueness of (type, slotOrder) is enforced in application code (not a DB
// unique index) so we can swap slots atomically without constraint violations.
model MediaAsset {
  id         String    @id @default(cuid())
  type       MediaType                       // BACKGROUND / AVATAR / COVER / CV / VIDEO_BACKGROUND
  url        String                          // link to the stored file
  filename   String                          // original name, for the admin list
  isActive   Boolean   @default(false)       // one active per type (single-slot system)
  slotOrder  Int?                            // numbered slot within type: 1=image1, 2=image2 …
  version    Int       @default(1)           // for cache-busting (?v=N)
  createdAt  DateTime  @default(now())

  @@index([type, isActive])
  @@index([type, slotOrder])
}

enum MediaType {
  BACKGROUND
  AVATAR
  COVER
  CV
  VIDEO_BACKGROUND
  FAVICON
}

// External links (social profiles, external sites, anything URL-based). Same
// "add-many, activate, slot" pattern as MediaAsset, but a link has no stored
// file — just a url + a human label. Themes read the active link via
// {{ profile.link }} / {{ profile.link_label }}, numbered slots via
// {{ profile.link1 }} (+ _label), and the full slotted list via
// {% for l in profile.links %}{{ l.url }} / {{ l.label }}{% endfor %}.
// slotOrder uniqueness is enforced in application code (like MediaAsset).
model LinkAsset {
  id        String   @id @default(cuid())
  url       String                          // the external URL
  label     String                          // visible text, e.g. "My GitHub"
  // Optional named key (e.g. "github"). When set, the link is exposed to themes
  // as {{ profile.link_<key> }} (+ _label) for direct, named lookup — ideal for
  // social profiles. A keyed link ALSO still works in the slot system. Keys are
  // a safe slug shape; on collision the most recently created link wins.
  key       String?
  isActive  Boolean  @default(false)        // canonical active (many allowed)
  slotOrder Int?                            // numbered slot: 1=link1, 2=link2 …
  createdAt DateTime @default(now())

  @@index([isActive])
  @@index([slotOrder])
  @@index([key])
}
